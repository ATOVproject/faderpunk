+/// Issue a rising edge on an aux GPO and spawn a task to release it after
+/// `trigger_len` ms. The rising edge is enqueued onto `MAX_CHANNEL` so that
+/// simultaneous calls reach the MAX driver in the exact order they are made
+/// here — this is what gives `send_analog_ticks` its deterministic ordering.
+fn trigger_analog_tick(spawner: &Spawner, aux_no: usize, trigger_len: u64) {
+    let gpo_index = 17 + aux_no;
+
+    // Only raise the edge if we also have room to schedule its release,
+    // otherwise we'd strand the GPO high.
+    if spawner
+        .spawn(analog_tick_release(aux_no, trigger_len))
+        .is_ok()
+    {
+        MAX_CHANNEL
+            .sender()
+            .try_send((gpo_index, MaxCmd::GpoSetHigh))
+            .ok();
+    }
+}
